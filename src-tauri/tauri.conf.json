{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VNMark",
  "version": "0.1.0",
  "identifier": "vn.vnmark.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VNMark-VIỆT NAM THỊNH VƯỢNG",
        "width": 1180,
        "height": 780,
        "minWidth": 380,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
